# Supabase — Frontend (anon key only, never service role key)
# After `pnpm db:start`, copy values from `pnpm exec supabase status` into .env.local
# Access control is enforced by Row Level Security (RLS) — the anon key is safe to expose.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
